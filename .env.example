# Resend (https://resend.com) — powers the blog "subscribe by email" form.
RESEND_API_KEY=

# Optional: sender address for subscription emails. Must be on a domain verified
# in your Resend account. Falls back to Resend's sandbox sender if unset, which
# only works for testing, not real subscribers.
# RESEND_FROM_EMAIL="mleg.tech <newsletter@mleg.tech>"
